@using Site.Features.Blog;
@model (List<VmCategoryClientList> Categories, List<VmBlogClientShortLink> LatestBlogs, List<VmBlogClientShortLink> RecommendedBlogs)
<div class="row gy-4">
    <div class="col-12">
        <h6>دسته بندی ها</h6>
        <div class="list-group">
            @foreach (var item in Model.Categories)
            {
                <a asp-page="Search" asp-route-categoryId="@item.Id" title="@item.Title"
                class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    @item.Title
                    <span class="badge bg-primary rounded-pill">@item.BlogCount</span>
                </a>
            }
        </div>
    </div>
    <div class="col-12">
        <h6>آخرین مقاله ها</h6>
        <div class="list-group">
            @foreach (var item in Model.LatestBlogs)
            {
                <a asp-page="BlogDetail" asp-route-id="@item.Id" title="@item.Title"
                class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    @item.Title
                </a>
            }
        </div>
    </div>
    <div class="col-12">
        <h6>مقالات پیشنهادی</h6>
        <div class="list-group">
            @foreach (var item in Model.RecommendedBlogs)
            {
                <a asp-page="BlogDetail" asp-route-id="@item.Id" title="@item.Title"
                class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    @item.Title
                </a>
            }
        </div>
    </div>
</div>